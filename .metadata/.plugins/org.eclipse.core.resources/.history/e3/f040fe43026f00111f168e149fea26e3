import java.util.Scanner;

public class bank {

    static Scanner sc = new Scanner(System.in);

    // Array to store customers
    static CustomerData customers[] = new CustomerData[100];

    static int count = 0;

    public static void main(String[] args) {

        System.out.println("      WELCOME TO HDFC BANK");

        System.out.println("1. Employee");
        System.out.println("2. Customer");

        System.out.print("Enter Your Choice: ");
        int choice = sc.nextInt();
        sc.nextLine();

        switch (choice) {

        case 1:
            emp e = new emp();
            break;

        case 2:
            customer c = new customer();
            break;

        default:
            System.out.println("Invalid Choice");
        }
    }
}

// Employee Class
class emp {

    public emp() {

        Scanner sc = new Scanner(System.in);

        System.out.println("\nWELCOME EMPLOYEE");

        System.out.print("Enter Employee Name: ");
        String empName = sc.nextLine();

        System.out.println("Employee Name: " + empName);
    }
}

// Customer Class
class customer {

    public customer() {

        Scanner sc = new Scanner(System.in);

        System.out.println("\nCUSTOMER MENU");

        System.out.println("1. Already a Customer");
        System.out.println("2. New Customer");

        System.out.print("Enter Your Choice: ");
        int ch = sc.nextInt();
        sc.nextLine();

        switch (ch) {

        case 1:
            login();
            break;

        case 2:
            register();
            break;

        default:
            System.out.println("Invalid Choice");
        }
    }

    // Registration Method
    void register() {

        Scanner sc = new Scanner(System.in);

        System.out.println("\nCUSTOMER REGISTRATION");

        System.out.print("Enter Name: ");
        String name = sc.nextLine();

        System.out.print("Enter Phone Number: ");
        String phone = sc.nextLine();

        // Duplicate Phone Check
        for (int i = 0; i < bank.count; i++) {

            if (bank.customers[i].phone.equals(phone)) {

                System.out.println(
                        "\nCustomer already registered with this phone number.");
                return;
            }
        }

        System.out.print("Enter Email: ");
        String email = sc.nextLine();

        System.out.print("Enter Account Type (Saving/Current): ");
        String accountType = sc.nextLine();

        System.out.print("Create Password: ");
        String password = sc.nextLine();

        double balance;

        do {

            System.out.print(
                    "Enter Security Deposit (Minimum ₹1000): ");

            balance = sc.nextDouble();

            if (balance < 1000) {

                System.out.println(
                        "Minimum Deposit Should Be ₹1000");
            }

        } while (balance < 1000);

        bank.customers[bank.count] =
                new CustomerData(
                        name,
                        phone,
                        email,
                        accountType,
                        password,
                        balance);

        bank.count++;

        System.out.println("Customer Registration Successful");
        System.out.println("Account Created Successfully");
        System.out.println("Your Customer ID: " + phone);

        System.out.println("\nPlease Login To Continue...");
        login();
    }

    // Login Method
    void login() {

        Scanner sc = new Scanner(System.in);

        System.out.println("\nCUSTOMER LOGIN");

        System.out.print("Enter Customer ID (Phone Number): ");
        String phone = sc.nextLine();

        System.out.print("Enter Password: ");
        String password = sc.nextLine();

        boolean found = false;

        for (int i = 0; i < bank.count; i++) {

            if (bank.customers[i].phone.equals(phone)
                    && bank.customers[i].password.equals(password)) {

                found = true;

                System.out.println("\n LOGIN SUCCESSFUL ");
                System.out.println("Welcome " + bank.customers[i].name);
                System.out.println("Phone Number : " + bank.customers[i].phone);
                System.out.println("Email        : " + bank.customers[i].email);
                System.out.println("Account Type : " + bank.customers[i].accountType);

                customerMenu(bank.customers[i]);

                break;
            }
        }

        if (!found) {

            System.out.println(
                    "\nNo customer found with the given Customer ID or Password.");
        }
    }

    void customerMenu(CustomerData cust) {

        Scanner sc = new Scanner(System.in);

        int choice;

        do {

            System.out.println("\n===== CUSTOMER SERVICES =====");

            System.out.println("1. Withdraw");
            System.out.println("2. Deposit");
            System.out.println("3. Check Balance");
            System.out.println("4. Logout");

            System.out.print("Enter Choice: ");
            choice = sc.nextInt();

            switch (choice) {

            case 1:
                withdraw(cust);
                break;

            case 2:
                deposit(cust);
                break;

            case 3:
                checkBalance(cust);
                break;

            case 4:
                System.out.println("Logout Successful");
                break;

            default:
                System.out.println("Invalid Choice");
            }

        } while (choice != 4);
    }

    void withdraw(CustomerData cust) {

        Scanner sc = new Scanner(System.in);

        System.out.print("Enter Amount To Withdraw: ");

        double amount = sc.nextDouble();

        if (amount <= cust.balance) {

            cust.balance = cust.balance - amount;

            System.out.println("Money Withdrawn Successfully");

            System.out.println(
                    "Remaining Balance: ₹" + cust.balance);
        }

        else {

            System.out.println("Insufficient Balance");
        }
    }

    void deposit(CustomerData cust) {

        Scanner sc = new Scanner(System.in);

        System.out.print("Enter Amount To Deposit: ");

        double amount = sc.nextDouble();

        cust.balance = cust.balance + amount;

        System.out.println("Amount Deposited Successfully");

        System.out.println(
                "Updated Balance: ₹" + cust.balance);
    }

    void checkBalance(CustomerData cust) {

        System.out.println(
                "Available Balance: ₹" + cust.balance);
    }
}

// Customer Data Class
class CustomerData {

    String name;
    String phone;
    String email;
    String accountType;
    String password;
    double balance;

    public CustomerData(
            String name,
            String phone,
            String email,
            String accountType,
            String password,
            double balance) {

        this.name = name;
        this.phone = phone;
        this.email = email;
        this.accountType = accountType;
        this.password = password;
        this.balance = balance;
    }
}