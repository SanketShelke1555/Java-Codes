import java.util.Scanner;

public class bank {

    static Scanner sc = new Scanner(System.in);

    // Array to store customers
    static CustomerData customers[] = new CustomerData[100];

    static int count = 0;

    public static void main(String[] args) {

       
        System.out.println("      WELCOME TO HDFC BANK");
       

        System.out.println("1. Employee");
        System.out.println("2. Customer");

        System.out.print("Enter Your Choice: ");
        int choice = sc.nextInt();
        sc.nextLine();

        switch (choice) {

        case 1:
            emp e = new emp();
            break;

        case 2:
            customer c = new customer();
            break;

        default:
            System.out.println("Invalid Choice");
        }
    }
}

// Employee Class
class emp {

    public emp() {

        Scanner sc = new Scanner(System.in);

        System.out.println("\nWELCOME EMPLOYEE");

        System.out.print("Enter Employee Name: ");
        String empName = sc.nextLine();

        System.out.println("Employee Name: " + empName);
    }
}

// Customer Class
class customer {

    public customer() {

        Scanner sc = new Scanner(System.in);

        System.out.println("\nCUSTOMER MENU");

        System.out.println("1. Already a Customer");
        System.out.println("2. New Customer");

        System.out.print("Enter Your Choice: ");
        int ch = sc.nextInt();
        sc.nextLine();

        switch (ch) {

        case 1:
            login();
            break;

        case 2:
            register();
            break;

        default:
            System.out.println("Invalid Choice");
        }
    }

    // Registration Method
    void register() {

        Scanner sc = new Scanner(System.in);

        System.out.println("\nCUSTOMER REGISTRATION");

        System.out.print("Enter Name: ");
        String name = sc.nextLine();

        System.out.print("Enter Phone Number: ");
        String phone = sc.nextLine();

        // Duplicate Phone Check
        for (int i = 0; i < bank.count; i++) {

            if (bank.customers[i].phone.equals(phone)) {

                System.out.println(
                        "\nCustomer already registered with this phone number.");
                return;
            }
        }

        System.out.print("Enter Email: ");
        String email = sc.nextLine();

        System.out.print("Enter Account Type (Saving/Current): ");
        String accountType = sc.nextLine();

        System.out.print("Create Password: ");
        String password = sc.nextLine();

        bank.customers[bank.count] =
                new CustomerData(
                        name,
                        phone,
                        email,
                        accountType,
                        password);

        bank.count++;

        
        System.out.println("Customer Registration Successful");
        System.out.println("Account Created Successfully");
        System.out.println("Your Customer ID: " + phone);
        
        System.out.println("\nPlease Login To Continue...");
        login();
    }

    // Login Method
    void login() {

        Scanner sc = new Scanner(System.in);

        System.out.println("\nCUSTOMER LOGIN");

        System.out.print("Enter Customer ID (Phone Number): ");
        String phone = sc.nextLine();

        System.out.print("Enter Password: ");
        String password = sc.nextLine();

        boolean found = false;

        for (int i = 0; i < bank.count; i++) {

            if (bank.customers[i].phone.equals(phone)
                    && bank.customers[i].password.equals(password)) {

                found = true;

                System.out.println("\n LOGIN SUCCESSFUL ");
                System.out.println("Welcome " + bank.customers[i].name);
                System.out.println("Phone Number : " + bank.customers[i].phone);
                System.out.println("Email        : " + bank.customers[i].email);
                System.out.println("Account Type : " + bank.customers[i].accountType);

                break;
            }
        }

        if (!found) {

            System.out.println(
                    "\nNo customer found with the given Customer ID or Password.");
        }
    }
}

// Customer Data Class
class CustomerData {

    String name;
    String phone;
    String email;
    String accountType;
    String password;

    public CustomerData(
            String name,
            String phone,
            String email,
            String accountType,
            String password, 
    		double balance){

        this.name = name;
        this.phone = phone;
        this.email = email;
        this.accountType = accountType;
        this.password = password;
    }
}